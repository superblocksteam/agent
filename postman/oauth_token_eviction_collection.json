          "raw": "{\n  \"options\": {\n    \"includeEventOutputs\": true\n  },\n  \"definition\": {\n    \"api\": {\n      \"metadata\": {\n        \"id\": \"00000000-0000-0000-0000-0000000000b2\",\n        \"organization\": \"00000000-0000-0000-0000-000000000001\",\n        \"name\": \"OAuthEvictP2Shared\"\n      },\n      \"blocks\": [\n        {\n          \"name\": \"q\",\n          \"step\": {\n            \"integration\": \"databricks\",\n            \"databricks\": {\n              \"runSql\": {\n                \"sqlBody\": \"SELECT 1\"\n              }\n            }\n          }\n        }\n      ]\n    },\n    \"integrations\": {\n      \"databricks\": {\n        \"id\": \"databricks-obo-cfg-2\",\n        \"authType\": \"oauth-token-exchange\",\n        \"connection\": {\n          \"connectionType\": \"CONNECTION_TYPE_OAUTH_EXCHANGE\",\n          \"hostUrl\": \"mock_databricks\",\n          \"path\": \"/sql/1.0/endpoints/mock\",\n          \"port\": 8443\n        },\n        \"authConfig\": {\n          \"tokenUrl\": \"https://mock_databricks:8443/oidc/v1/token\",\n          \"clientId\": \"test-client-id\",\n          \"clientSecret\": \"test-secret\",\n          \"tokenScope\": \"datasource\"\n        }\n      }\n    }\n  }\n}"
        },
