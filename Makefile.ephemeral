# ============================================================================
# Ephemeral Worker Development (Native Builds)
# ============================================================================
#
# Run from the orchestrator repo. Orchestrator + task-managers + JavaScript
# sandboxes + go-worker; builds and runs Go/Node natively with Redis + Python
# sandbox in Docker. Matches cloud staging worker topology (see profiles/lib/
# local-orch-shared.tilt in the workspace monorepo):
#
#   orchestrator
#     -> task-manager-js        (plugins=javascript)
#     -> task-manager-js-aux    (plugins=*,-javascript,-javascriptsdkapi,-python)
#     -> task-manager-sdkapi    (plugins=javascriptsdkapi, dedicated sandbox)
#     -> task-manager-py        (plugins=python, sandbox in Docker)
#     -> go-worker              (v8 bucket BA)
#
# All-in-one (recommended):
#   make ephemeral-up        # Kill, rebuild, start all services (background)
#   make ephemeral-logs      # Tail all logs
#   make ephemeral-status    # Check what's running
#   make ephemeral-down      # Stop everything
#
# Requirements:
#   Node.js:    pinned by .nvmrc (Node 22). The JS sandbox depends on
#               deasync@0.1.29 which only ships prebuilt darwin-arm64 bindings
#               up to node-22, so newer Node breaks the sandbox at module
#               load. The Makefile auto-resolves the right Node (see NODE_BIN
#               below) from ~/.nvm or ~/.fnm. Run `make ephemeral-check-node`
#               to verify, or override with `NODE_BIN=/abs/path/to/node make`.
#   Server:     SUPERBLOCKS_AGENT_SERVER_URL must be reachable (orchestrator
#               exits on /api/v1/agents/register failure). For local server,
#               run `pnpm dev` in repos/superblocks first.
#
# OPA-equivalent env vars (same as public Docker Compose agent steps):
#   SUPERBLOCKS_AGENT_SERVER_URL or __SUPERBLOCKS_AGENT_SERVER_URL  -> --superblocks.url (e.g. https://staging.superblocks.com, https://pr-1234.superblocks.dev)
#   SUPERBLOCKS_AGENT_KEY                                           -> --superblocks.key (registered agent key)
#   SUPERBLOCKS_AGENT_HOST_URL                                      -> --agent.host.url + listen port (e.g. http://localhost:18080)
#   SUPERBLOCKS_AGENT_DATA_DOMAIN                                   -> --data.domain (e.g. app.superblocks.com)
#   SUPERBLOCKS_ORCHESTRATOR_REGISTRATION_ENABLED                   -> --registration.enabled (default true so agent connects)
#   SUPERBLOCKS_ORCHESTRATOR_AUTH_JWT_JWKS_URL                      -> --auth.jwt.jwks_url (default: staging CDN; works for staging + pr-*.superblocks.dev)
#   SUPERBLOCKS_ORCHESTRATOR_WORKER_GO_ENABLED                      -> --worker.go.enabled (default false; set true when ephemeral-go-worker is running)
#
# Example (OPA against a PR env, all workers):
#   SUPERBLOCKS_AGENT_SERVER_URL=https://pr-1234.superblocks.dev \
#   SUPERBLOCKS_AGENT_KEY=<AGENT_KEY> \
#   SUPERBLOCKS_AGENT_HOST_URL=http://localhost:18080 \
#   make ephemeral-up
#
# Example (orchestrator-only, staging, health at :8080, agent connects):
#   SUPERBLOCKS_AGENT_SERVER_URL=https://staging.superblocks.com \
#   SUPERBLOCKS_AGENT_KEY=<AGENT_KEY> \
#   SUPERBLOCKS_AGENT_HOST_URL=http://localhost:8080 \
#   SUPERBLOCKS_AGENT_DATA_DOMAIN=app.superblocks.com \
#   make ephemeral-deps ephemeral-orchestrator
#
# ============================================================================

# Paths: run from orchestrator repo
ORCH_SRC        = $(CURDIR)

# Configuration
EPHEMERAL_REDIS_PASSWORD ?= koala
EPHEMERAL_COMPOSE_FILE   = $(CURDIR)/compose.ephemeral-dev.yaml

# Source directories (orchestrator repo)
TM_DIR          = $(ORCH_SRC)/workers/ephemeral/task-manager
TM_BINARY       = $(TM_DIR)/task-manager
JS_WORKSPACE    = $(ORCH_SRC)/workers/javascript
JS_SANDBOX_DIR  = $(ORCH_SRC)/workers/ephemeral/javascript-plugins-sandbox
JS_SANDBOX_DEPLOY_DIR = $(JS_SANDBOX_DIR)/.deploy
GO_WORKER_DIR   = $(ORCH_SRC)/workers/golang
GO_WORKER_BIN   = $(GO_WORKER_DIR)/worker-go
ORCH_BINARY     = $(ORCH_SRC)/orchestrator

# JS task-manager ports
JS_TM_VAR_STORE_GRPC_PORT    ?= 50050
JS_TM_VAR_STORE_HTTP_PORT    ?= 8085
JS_TM_STREAMING_PORT         ?= 50052
JS_TM_INTEGRATION_EXEC_PORT  ?= 50053
JS_SANDBOX_PORT              ?= 50051

# Auxiliary JS task-manager ports (plugins=*,-javascript,-javascriptsdkapi,-python)
# Shares the regular JS sandbox since non-JS plugins don't need a dedicated sandbox.
AUX_TM_VAR_STORE_GRPC_PORT   ?= 50080
AUX_TM_VAR_STORE_HTTP_PORT   ?= 8086
AUX_TM_STREAMING_PORT        ?= 50082
AUX_TM_INTEGRATION_EXEC_PORT ?= 50083

# JavaScript SDK API task-manager + dedicated sandbox (Code Mode API 2.0)
SDKAPI_TM_VAR_STORE_GRPC_PORT    ?= 50070
SDKAPI_TM_VAR_STORE_HTTP_PORT    ?= 8075
SDKAPI_TM_STREAMING_PORT         ?= 50072
SDKAPI_TM_INTEGRATION_EXEC_PORT  ?= 50073
SDKAPI_SANDBOX_PORT              ?= 50071

# Python task-manager ports (offset to avoid conflicts with JS)
PY_TM_VAR_STORE_GRPC_PORT    ?= 50060
PY_TM_VAR_STORE_HTTP_PORT    ?= 8095
PY_TM_STREAMING_PORT         ?= 50062
PY_TM_INTEGRATION_EXEC_PORT  ?= 50063
PY_SANDBOX_PORT              ?= 50061

# Orchestrator ports (HTTP port is used for /health and the advertised agent URL)
ORCH_HTTP_PORT    ?= 18080
# When SUPERBLOCKS_AGENT_HOST_URL is set, use its port so the orchestrator listens where it advertises
AGENT_HOST_PORT   := $(shell echo '$(SUPERBLOCKS_AGENT_HOST_URL)' | sed -n 's|.*:\([0-9]*\)/*.*|\1|p')
ifneq ($(AGENT_HOST_PORT),)
ORCH_HTTP_PORT    := $(AGENT_HOST_PORT)
endif
ORCH_GRPC_PORT    ?= 8081
ORCH_METRICS_PORT ?= 9091
ORCH_PPROF_PORT   ?= 7777

# Node.js binary used for the JS sandboxes. The repo pins a specific version
# in .nvmrc; deasync@0.1.29 only ships prebuilt darwin-arm64 bindings up to
# Node 22, so running with a newer Node breaks the sandbox at startup with
# "Could not locate the bindings file". Resolution order:
#   1. NODE_BIN env override
#   2. nvm install of the .nvmrc version
#   3. fnm install of the .nvmrc version
#   4. `node` on PATH (validated by ephemeral-check-node)
NVMRC_VERSION := $(shell sed 's/^v//' $(ORCH_SRC)/.nvmrc 2>/dev/null | tr -d '[:space:]')
NVMRC_MAJOR   := $(firstword $(subst ., ,$(NVMRC_VERSION)))
NODE_BIN      ?= $(shell \
	if [ -n "$(NVMRC_VERSION)" ] && [ -x "$$HOME/.nvm/versions/node/v$(NVMRC_VERSION)/bin/node" ]; then \
		echo "$$HOME/.nvm/versions/node/v$(NVMRC_VERSION)/bin/node"; \
	elif [ -n "$(NVMRC_VERSION)" ] && [ -x "$$HOME/.fnm/node-versions/v$(NVMRC_VERSION)/installation/bin/node" ]; then \
		echo "$$HOME/.fnm/node-versions/v$(NVMRC_VERSION)/installation/bin/node"; \
	else \
		command -v node 2>/dev/null || true; \
	fi)
NODE_BIN_DIR  := $(patsubst %/,%,$(dir $(NODE_BIN)))

# Make helper: literal comma for use inside $(call ...)
, := ,

# Local defaults aligned with cloud ephemeral routing behavior. Plugin routing
# matches staging: dedicated JS TM for `javascript`, dedicated SDK API TM for
# `javascriptsdkapi`, dedicated Python TM for `python`, aux TM for everything
# else (postgres, restapi, s3, ...). When changing these, ensure no two TMs
# claim the same plugin; duplicate claims cause "no handler" / race errors.
SUPERBLOCKS_WORKER_SANDBOX_JS_PLUGINS     ?= javascript
SUPERBLOCKS_WORKER_SANDBOX_AUX_PLUGINS    ?= *,-javascript,-javascriptsdkapi,-python
SUPERBLOCKS_WORKER_SANDBOX_SDKAPI_PLUGINS ?= javascriptsdkapi
SUPERBLOCKS_WORKER_SANDBOX_PY_PLUGINS     ?= python

# Common task-manager environment. SUPERBLOCKS_WORKER_SANDBOX_SUPERBLOCKS_KEY
# is forwarded so task-managers sign their outbound HTTP to the Superblocks
# server (e.g. fetching API definitions) with the same agent key the orch uses.
define TM_COMMON_ENV
SUPERBLOCKS_WORKER_SANDBOX_TRANSPORT_REDIS_HOST=127.0.0.1 \
SUPERBLOCKS_WORKER_SANDBOX_TRANSPORT_REDIS_PORT=6379 \
SUPERBLOCKS_WORKER_SANDBOX_TRANSPORT_REDIS_PASSWORD=$(EPHEMERAL_REDIS_PASSWORD) \
SUPERBLOCKS_WORKER_SANDBOX_TRANSPORT_REDIS_TLS=false \
SUPERBLOCKS_WORKER_SANDBOX_STORE_REDIS_HOST=127.0.0.1 \
SUPERBLOCKS_WORKER_SANDBOX_STORE_REDIS_PORT=6379 \
SUPERBLOCKS_WORKER_SANDBOX_STORE_REDIS_PASSWORD=$(EPHEMERAL_REDIS_PASSWORD) \
SUPERBLOCKS_WORKER_SANDBOX_STORE_REDIS_TLS=false \
SUPERBLOCKS_WORKER_SANDBOX_WORKER_EPHEMERAL=false \
SUPERBLOCKS_WORKER_SANDBOX_IP_FILTER_DISABLED=true \
SUPERBLOCKS_WORKER_SANDBOX_WORKER_EVENTS="execute metadata test pre_delete" \
SUPERBLOCKS_WORKER_SANDBOX_WORKER_BUCKETS="BA BE B1 B2" \
SUPERBLOCKS_WORKER_SANDBOX_WORKER_STREAM_VARIANTS=$(SUPERBLOCKS_WORKER_STREAM_VARIANT) \
SUPERBLOCKS_WORKER_SANDBOX_ORCHESTRATOR_GRPC_ADDRESS=127.0.0.1:$(ORCH_GRPC_PORT) \
SUPERBLOCKS_WORKER_SANDBOX_SUPERBLOCKS_KEY=$${SUPERBLOCKS_AGENT_KEY-dev-agent-key}
endef

# ============================================================================
# Docker Dependencies
# ============================================================================

.PHONY: ephemeral-deps
ephemeral-deps:
	EPHEMERAL_REDIS_PASSWORD=$(EPHEMERAL_REDIS_PASSWORD) docker compose -f $(EPHEMERAL_COMPOSE_FILE) up -d
	@echo ""
	@echo "==> Redis running on localhost:6379 (password: $(EPHEMERAL_REDIS_PASSWORD))"
	@echo "==> Python sandbox running on localhost:$(PY_SANDBOX_PORT)"
	@echo ""

.PHONY: ephemeral-deps-down
ephemeral-deps-down:
	EPHEMERAL_REDIS_PASSWORD=$(EPHEMERAL_REDIS_PASSWORD) docker compose -f $(EPHEMERAL_COMPOSE_FILE) down -v

# ============================================================================
# Node.js Version Check
# ============================================================================

# Verifies the resolved NODE_BIN matches .nvmrc (or at least the same major).
# Fails fast with a clear install hint when missing. The JS sandbox needs the
# pinned major because deasync@0.1.29 only ships prebuilt bindings up to Node
# 22 for darwin-arm64 (and Node 20 for older platforms).
.PHONY: ephemeral-check-node
ephemeral-check-node:
	@if [ -z "$(NODE_BIN)" ] || [ ! -x "$(NODE_BIN)" ]; then \
		echo "==> ERROR: cannot resolve a Node.js binary."; \
		echo "    .nvmrc pins v$(NVMRC_VERSION); install via nvm or fnm:"; \
		echo "        nvm install $(NVMRC_VERSION) && nvm use $(NVMRC_VERSION)"; \
		echo "        fnm install $(NVMRC_VERSION) && fnm use $(NVMRC_VERSION)"; \
		echo "    Or set NODE_BIN=/abs/path/to/node when invoking make."; \
		exit 1; \
	fi
	@actual=$$($(NODE_BIN) --version | sed 's/^v//'); \
	major=$${actual%%.*}; \
	echo "==> Using Node $$actual ($(NODE_BIN))"; \
	if [ -n "$(NVMRC_MAJOR)" ] && [ "$$major" != "$(NVMRC_MAJOR)" ]; then \
		echo "==> ERROR: Node $$actual does not match .nvmrc (v$(NVMRC_VERSION))."; \
		echo "    The JS sandbox needs Node $(NVMRC_MAJOR) for prebuilt deasync bindings;"; \
		echo "    a mismatch causes 'Could not locate the bindings file' at module load."; \
		echo "    Install: nvm install $(NVMRC_VERSION) && nvm use $(NVMRC_VERSION)"; \
		echo "    Or set NODE_BIN=/abs/path/to/node-$(NVMRC_MAJOR) when invoking make."; \
		exit 1; \
	fi

# ============================================================================
# Build Targets
# ============================================================================

.PHONY: ephemeral-build-orchestrator
ephemeral-build-orchestrator:
	@echo "==> Building orchestrator..."
	@cd $(ORCH_SRC) && make build-go EXTRA_GO_OPTIONS='-cover'

.PHONY: ephemeral-build-task-manager
ephemeral-build-task-manager:
	@echo "==> Building task-manager..."
	@cd $(TM_DIR) && CGO_ENABLED=1 go build -ldflags="-s -w" -o task-manager ./cmd/task-manager

.PHONY: ephemeral-build-go-worker
ephemeral-build-go-worker:
	@echo "==> Building go-worker..."
	@cd $(GO_WORKER_DIR) && CGO_ENABLED=1 go build -ldflags="-s -w" -o worker-go ./cmd/worker.go/...

.PHONY: ephemeral-build-js-sandbox
ephemeral-build-js-sandbox: ephemeral-check-node
	@echo "==> Building JavaScript sandbox (this may take a while on first run)..."
	@cd $(JS_WORKSPACE) && export PATH="$(NODE_BIN_DIR):$$PATH" && pnpm install && \
	for pkg in lz4 deasync bcrypt cpu-features nice-napi; do \
		echo "==> Rebuilding native module: $$pkg"; \
		find node_modules/.pnpm -path "*/$${pkg}@*/node_modules/$${pkg}" -type d 2>/dev/null | xargs -I{} sh -c 'cd "{}" && npm rebuild' || true; \
	done && \
	echo "==> Building transitive dependencies of javascript-plugins-sandbox (plugins, worker.js, etc.)..." && \
	pnpm --filter 'javascript-plugins-sandbox^...' run build && \
	echo "==> Re-linking workspace packages after plugin builds (Dockerfile.sandbox.javascript phase 1)..." && \
	pnpm install && \
	echo "==> Generating type declarations for sandbox dependencies..." && \
	pnpm --filter @superblocks/worker.js typecheck && \
	pnpm --filter @superblocksteam/javascript-sdk-api typecheck && \
	echo "==> Building javascript-plugins-sandbox..." && \
	pnpm --filter javascript-plugins-sandbox run clean && \
	pnpm --filter javascript-plugins-sandbox build && \
	echo "==> Re-linking workspace packages after sandbox build (Dockerfile.sandbox.javascript phase 2)..." && \
	pnpm install && \
	echo "==> Deploying javascript-plugins-sandbox for local runtime..." && \
	rm -rf $(JS_SANDBOX_DEPLOY_DIR) && \
	pnpm --filter javascript-plugins-sandbox deploy --prod $(JS_SANDBOX_DEPLOY_DIR)
	@mkdir -p $(JS_SANDBOX_DEPLOY_DIR)/node_modules/@superblocksteam/javascript-sdk-api-wasm/dist/src/bundles
	@if [ ! -f $(JS_SANDBOX_DEPLOY_DIR)/node_modules/@superblocksteam/javascript-sdk-api-wasm/dist/src/bundles/sdk-api.iife.js ]; then \
		cp $(JS_WORKSPACE)/packages/plugins/javascript-sdk-api-wasm/dist/src/bundles/sdk-api.iife.js \
		   $(JS_SANDBOX_DEPLOY_DIR)/node_modules/@superblocksteam/javascript-sdk-api-wasm/dist/src/bundles/sdk-api.iife.js; \
	fi
	@test -f $(JS_SANDBOX_DEPLOY_DIR)/node_modules/@superblocksteam/javascript-sdk-api-wasm/dist/src/bundles/sdk-api.iife.js \
	  || (echo "ERROR: sdk-api.iife.js missing from deploy" && exit 1)
	@if [ -d $(JS_SANDBOX_DIR)/src/types ]; then \
		echo "==> Copying protobuf types to JS sandbox deploy dist..."; \
		mkdir -p $(JS_SANDBOX_DEPLOY_DIR)/dist/types && \
		cp -R $(JS_SANDBOX_DIR)/src/types/. $(JS_SANDBOX_DEPLOY_DIR)/dist/types/; \
	fi

JS_LOCKFILE              = $(ORCH_SRC)/pnpm-lock.yaml
JS_WORKSPACE_CONFIG      = $(ORCH_SRC)/pnpm-workspace.yaml
JS_SANDBOX_DEPLOY_INDEX  = $(JS_SANDBOX_DEPLOY_DIR)/dist/index.js

# Rebuild .deploy when sandbox sources, plugin workspace sources, lockfiles, or this
# Makefile change. A lockfile-only check misses code edits; scanning source trees
# avoids serving stale deploy output after `make ephemeral-up`.
.PHONY: ephemeral-build-js-sandbox-if-needed
ephemeral-build-js-sandbox-if-needed:
	@deploy='$(JS_SANDBOX_DEPLOY_INDEX)'; \
	reason=''; \
	if [ ! -f "$$deploy" ]; then \
		reason='deploy dist missing'; \
	elif [ -f '$(JS_LOCKFILE)' ] && [ '$(JS_LOCKFILE)' -nt "$$deploy" ]; then \
		reason='pnpm-lock.yaml changed'; \
	elif [ -f '$(JS_WORKSPACE_CONFIG)' ] && [ '$(JS_WORKSPACE_CONFIG)' -nt "$$deploy" ]; then \
		reason='pnpm-workspace.yaml changed'; \
	elif [ '$(CURDIR)/Makefile.ephemeral' -nt "$$deploy" ]; then \
		reason='Makefile.ephemeral changed'; \
	elif [ '$(JS_SANDBOX_DIR)/package.json' -nt "$$deploy" ]; then \
		reason='javascript-plugins-sandbox/package.json changed'; \
	elif find \
		'$(JS_SANDBOX_DIR)/src' \
		'$(JS_WORKSPACE)/packages' \
		'$(ORCH_SRC)/types/gen/js' \
		-type f \
		! -path '*/node_modules/*' \
		! -path '*/dist/*' \
		! -path '*/.deploy/*' \
		! -path '*/coverage/*' \
		! -name '*.tsbuildinfo' \
		-newer "$$deploy" \
		-print -quit 2>/dev/null | grep -q .; then \
		reason='sandbox or plugin sources changed'; \
	fi; \
	if [ -n "$$reason" ]; then \
		echo "==> JS sandbox deploy stale ($$reason), rebuilding..."; \
		$(MAKE) ephemeral-build-js-sandbox; \
	else \
		echo "==> JS sandbox deploy dist up to date, skipping (make ephemeral-build-js-sandbox to force)"; \
	fi
	@if [ -d $(JS_SANDBOX_DIR)/src/types ] && [ ! -d $(JS_SANDBOX_DEPLOY_DIR)/dist/types ]; then \
		echo "==> Copying protobuf types to JS sandbox deploy dist..."; \
		mkdir -p $(JS_SANDBOX_DEPLOY_DIR)/dist/types && \
		cp -R $(JS_SANDBOX_DIR)/src/types/. $(JS_SANDBOX_DEPLOY_DIR)/dist/types/; \
	fi

.PHONY: ephemeral-build-go
ephemeral-build-go: ephemeral-build-orchestrator ephemeral-build-task-manager ephemeral-build-go-worker ephemeral-build-js-sandbox-if-needed
	@echo ""
	@echo "==> Build complete"

.PHONY: ephemeral-build
ephemeral-build: ephemeral-build-orchestrator ephemeral-build-task-manager ephemeral-build-go-worker ephemeral-build-js-sandbox
	@echo ""
	@echo "==> All ephemeral binaries built successfully"

# ============================================================================
# Run Targets (each runs in foreground - use separate terminals)
# ============================================================================

.PHONY: ephemeral-orchestrator
ephemeral-orchestrator: ephemeral-build-orchestrator
	@echo "==> Starting orchestrator (HTTP=:$(ORCH_HTTP_PORT), gRPC=:$(ORCH_GRPC_PORT), metrics=:$(ORCH_METRICS_PORT), pprof=:$(ORCH_PPROF_PORT))..."
	@cd $(ORCH_SRC) && SUPERBLOCKS_AGENT_APP_ENV_TEST=ok \
	./orchestrator \
		--zen \
		--test=true \
		--log.level=debug \
		--transport.redis.password=$(EPHEMERAL_REDIS_PASSWORD) \
		--store.redis.password=$(EPHEMERAL_REDIS_PASSWORD) \
		--buckets.config=./buckets.minimal.json \
		--auth.jwt.enabled=true \
		--auth.jwt.jwks_url=$${SUPERBLOCKS_ORCHESTRATOR_AUTH_JWT_JWKS_URL:-https://staging-cdn.superblocks.com/.well-known/jwks.json} \
		--registration.enabled=$${SUPERBLOCKS_ORCHESTRATOR_REGISTRATION_ENABLED-true} \
		--quotas.enabled=false \
		--jobs.enabled=false \
		--http.bind=127.0.0.1 \
		--http.port=$(ORCH_HTTP_PORT) \
		--grpc.bind=127.0.0.1 \
		--metrics.port=$(ORCH_METRICS_PORT) \
		--pprof.enabled=true \
		--pprof.port=$(ORCH_PPROF_PORT) \
		--agent.host.url=$${SUPERBLOCKS_AGENT_HOST_URL:-http://localhost:$(ORCH_HTTP_PORT)} \
		--file.server.url=http://127.0.0.1:$(ORCH_HTTP_PORT)/v2/files \
		--superblocks.url=$${SUPERBLOCKS_ORCHESTRATOR_SUPERBLOCKS_URL:-$${SUPERBLOCKS_AGENT_SERVER_URL:-$${__SUPERBLOCKS_AGENT_SERVER_URL:-http://127.0.0.1:8080}}} \
		--superblocks.key=$${SUPERBLOCKS_AGENT_KEY-dev-agent-key} \
		--data.domain=$${SUPERBLOCKS_AGENT_DATA_DOMAIN-app.superblocks.com} \
		--worker.go.enabled=$${SUPERBLOCKS_ORCHESTRATOR_WORKER_GO_ENABLED-false} \
		--worker.stream.variant=$${SUPERBLOCKS_WORKER_STREAM_VARIANT-} \
		--otel.collector.http.url=http://127.0.0.1:4318

.PHONY: ephemeral-task-manager-js
ephemeral-task-manager-js: ephemeral-build-task-manager
	@echo "==> Starting JavaScript task-manager (var-store gRPC=:$(JS_TM_VAR_STORE_GRPC_PORT), HTTP=:$(JS_TM_VAR_STORE_HTTP_PORT))..."
	@$(TM_COMMON_ENV) \
	SUPERBLOCKS_WORKER_SANDBOX_WORKER_PLUGINS=$${SUPERBLOCKS_WORKER_SANDBOX_JS_PLUGINS-$(SUPERBLOCKS_WORKER_SANDBOX_JS_PLUGINS)} \
	SUPERBLOCKS_WORKER_SANDBOX_SANDBOX_ADDRESS=127.0.0.1:$(JS_SANDBOX_PORT) \
	SUPERBLOCKS_WORKER_SANDBOX_VARIABLE_STORE_GRPC_PORT=$(JS_TM_VAR_STORE_GRPC_PORT) \
	SUPERBLOCKS_WORKER_SANDBOX_VARIABLE_STORE_GRPC_ADDRESS=127.0.0.1:$(JS_TM_VAR_STORE_GRPC_PORT) \
	SUPERBLOCKS_WORKER_SANDBOX_VARIABLE_STORE_HTTP_PORT=$(JS_TM_VAR_STORE_HTTP_PORT) \
	SUPERBLOCKS_WORKER_SANDBOX_STREAMING_PROXY_GRPC_PORT=$(JS_TM_STREAMING_PORT) \
	SUPERBLOCKS_WORKER_SANDBOX_INTEGRATION_EXECUTOR_ENABLED=true \
	SUPERBLOCKS_WORKER_SANDBOX_INTEGRATION_EXECUTOR_GRPC_PORT=$(JS_TM_INTEGRATION_EXEC_PORT) \
	$(TM_BINARY)

# Auxiliary JS task-manager — handles non-JS/Python plugins (postgres, restapi,
# s3, etc.). Reuses the shared JS sandbox since these plugins don't execute
# user JS code; they run natively inside the task-manager / integration-executor.
.PHONY: ephemeral-task-manager-js-aux
ephemeral-task-manager-js-aux: ephemeral-build-task-manager
	@echo "==> Starting auxiliary JS task-manager (var-store gRPC=:$(AUX_TM_VAR_STORE_GRPC_PORT), HTTP=:$(AUX_TM_VAR_STORE_HTTP_PORT))..."
	@$(TM_COMMON_ENV) \
	SUPERBLOCKS_WORKER_SANDBOX_WORKER_PLUGINS="$${SUPERBLOCKS_WORKER_SANDBOX_AUX_PLUGINS-$(SUPERBLOCKS_WORKER_SANDBOX_AUX_PLUGINS)}" \
	SUPERBLOCKS_WORKER_SANDBOX_SANDBOX_ADDRESS=127.0.0.1:$(JS_SANDBOX_PORT) \
	SUPERBLOCKS_WORKER_SANDBOX_VARIABLE_STORE_GRPC_PORT=$(AUX_TM_VAR_STORE_GRPC_PORT) \
	SUPERBLOCKS_WORKER_SANDBOX_VARIABLE_STORE_GRPC_ADDRESS=127.0.0.1:$(AUX_TM_VAR_STORE_GRPC_PORT) \
	SUPERBLOCKS_WORKER_SANDBOX_VARIABLE_STORE_HTTP_PORT=$(AUX_TM_VAR_STORE_HTTP_PORT) \
	SUPERBLOCKS_WORKER_SANDBOX_STREAMING_PROXY_GRPC_PORT=$(AUX_TM_STREAMING_PORT) \
	SUPERBLOCKS_WORKER_SANDBOX_INTEGRATION_EXECUTOR_ENABLED=false \
	SUPERBLOCKS_WORKER_SANDBOX_INTEGRATION_EXECUTOR_GRPC_PORT=$(AUX_TM_INTEGRATION_EXEC_PORT) \
	$(TM_BINARY)

# JavaScript SDK API task-manager — handles javascriptsdkapi (Code Mode API 2.0).
# Uses a dedicated JS sandbox process (ephemeral-js-sandbox-sdkapi) to match
# staging isolation.
.PHONY: ephemeral-task-manager-sdkapi
ephemeral-task-manager-sdkapi: ephemeral-build-task-manager
	@echo "==> Starting SDK API task-manager (var-store gRPC=:$(SDKAPI_TM_VAR_STORE_GRPC_PORT), HTTP=:$(SDKAPI_TM_VAR_STORE_HTTP_PORT))..."
	@$(TM_COMMON_ENV) \
	SUPERBLOCKS_WORKER_SANDBOX_WORKER_PLUGINS=$${SUPERBLOCKS_WORKER_SANDBOX_SDKAPI_PLUGINS-$(SUPERBLOCKS_WORKER_SANDBOX_SDKAPI_PLUGINS)} \
	SUPERBLOCKS_WORKER_SANDBOX_SANDBOX_ADDRESS=127.0.0.1:$(SDKAPI_SANDBOX_PORT) \
	SUPERBLOCKS_WORKER_SANDBOX_VARIABLE_STORE_GRPC_PORT=$(SDKAPI_TM_VAR_STORE_GRPC_PORT) \
	SUPERBLOCKS_WORKER_SANDBOX_VARIABLE_STORE_GRPC_ADDRESS=127.0.0.1:$(SDKAPI_TM_VAR_STORE_GRPC_PORT) \
	SUPERBLOCKS_WORKER_SANDBOX_VARIABLE_STORE_HTTP_PORT=$(SDKAPI_TM_VAR_STORE_HTTP_PORT) \
	SUPERBLOCKS_WORKER_SANDBOX_STREAMING_PROXY_GRPC_PORT=$(SDKAPI_TM_STREAMING_PORT) \
	SUPERBLOCKS_WORKER_SANDBOX_INTEGRATION_EXECUTOR_ENABLED=true \
	SUPERBLOCKS_WORKER_SANDBOX_INTEGRATION_EXECUTOR_GRPC_PORT=$(SDKAPI_TM_INTEGRATION_EXEC_PORT) \
	$(TM_BINARY)

.PHONY: ephemeral-task-manager-py
ephemeral-task-manager-py: ephemeral-build-task-manager
	@echo "==> Starting Python task-manager (var-store gRPC=:$(PY_TM_VAR_STORE_GRPC_PORT), HTTP=:$(PY_TM_VAR_STORE_HTTP_PORT))..."
	@$(TM_COMMON_ENV) \
	SUPERBLOCKS_WORKER_SANDBOX_WORKER_PLUGINS=$${SUPERBLOCKS_WORKER_SANDBOX_PY_PLUGINS-$(SUPERBLOCKS_WORKER_SANDBOX_PY_PLUGINS)} \
	SUPERBLOCKS_WORKER_SANDBOX_SANDBOX_ADDRESS=127.0.0.1:$(PY_SANDBOX_PORT) \
	SUPERBLOCKS_WORKER_SANDBOX_VARIABLE_STORE_GRPC_PORT=$(PY_TM_VAR_STORE_GRPC_PORT) \
	SUPERBLOCKS_WORKER_SANDBOX_VARIABLE_STORE_GRPC_ADDRESS=127.0.0.1:$(PY_TM_VAR_STORE_GRPC_PORT) \
	SUPERBLOCKS_WORKER_SANDBOX_VARIABLE_STORE_HTTP_PORT=$(PY_TM_VAR_STORE_HTTP_PORT) \
	SUPERBLOCKS_WORKER_SANDBOX_STREAMING_PROXY_GRPC_PORT=$(PY_TM_STREAMING_PORT) \
	SUPERBLOCKS_WORKER_SANDBOX_INTEGRATION_EXECUTOR_GRPC_PORT=$(PY_TM_INTEGRATION_EXEC_PORT) \
	$(TM_BINARY)

.PHONY: ephemeral-js-sandbox
ephemeral-js-sandbox: ephemeral-build-js-sandbox
	@echo "==> Starting JavaScript sandbox (gRPC=:$(JS_SANDBOX_PORT))..."
	@cd $(JS_SANDBOX_DEPLOY_DIR) && env -u ELECTRON_RUN_AS_NODE \
	SUPERBLOCKS_WORKER_SANDBOX_TRANSPORT_GRPC_PORT=$(JS_SANDBOX_PORT) \
	SUPERBLOCKS_WORKER_SANDBOX_TRANSPORT_VARIABLE_STORE_ADDRESS=127.0.0.1:$(JS_TM_VAR_STORE_GRPC_PORT) \
	SUPERBLOCKS_WORKER_SANDBOX_TRANSPORT_VARIABLE_STORE_HTTP_ADDRESS=127.0.0.1:$(JS_TM_VAR_STORE_HTTP_PORT) \
	SUPERBLOCKS_WORKER_SANDBOX_TRANSPORT_STREAMING_PROXY_ADDRESS=127.0.0.1:$(JS_TM_STREAMING_PORT) \
	SUPERBLOCKS_WORKER_SANDBOX_TRANSPORT_INTEGRATION_EXECUTOR_ADDRESS=127.0.0.1:$(JS_TM_INTEGRATION_EXEC_PORT) \
	SUPERBLOCKS_AGENT_KEY="" \
	SUPERBLOCKS_TUNNEL_PRIVATE_KEY_RSA="" \
	SUPERBLOCKS_TUNNEL_PRIVATE_KEY_ED25519="" \
	$(NODE_BIN) dist/index.js

# Dedicated JS sandbox for the SDK API task-manager. Same binary, different
# ports so the two sandbox processes are isolated (matches staging).
.PHONY: ephemeral-js-sandbox-sdkapi
ephemeral-js-sandbox-sdkapi: ephemeral-build-js-sandbox
	@echo "==> Starting SDK API JavaScript sandbox (gRPC=:$(SDKAPI_SANDBOX_PORT))..."
	@cd $(JS_SANDBOX_DEPLOY_DIR) && env -u ELECTRON_RUN_AS_NODE \
	SUPERBLOCKS_WORKER_SANDBOX_TRANSPORT_GRPC_PORT=$(SDKAPI_SANDBOX_PORT) \
	SUPERBLOCKS_WORKER_SANDBOX_TRANSPORT_VARIABLE_STORE_ADDRESS=127.0.0.1:$(SDKAPI_TM_VAR_STORE_GRPC_PORT) \
	SUPERBLOCKS_WORKER_SANDBOX_TRANSPORT_VARIABLE_STORE_HTTP_ADDRESS=127.0.0.1:$(SDKAPI_TM_VAR_STORE_HTTP_PORT) \
	SUPERBLOCKS_WORKER_SANDBOX_TRANSPORT_STREAMING_PROXY_ADDRESS=127.0.0.1:$(SDKAPI_TM_STREAMING_PORT) \
	SUPERBLOCKS_WORKER_SANDBOX_TRANSPORT_INTEGRATION_EXECUTOR_ADDRESS=127.0.0.1:$(SDKAPI_TM_INTEGRATION_EXEC_PORT) \
	SUPERBLOCKS_AGENT_KEY="" \
	SUPERBLOCKS_TUNNEL_PRIVATE_KEY_RSA="" \
	SUPERBLOCKS_TUNNEL_PRIVATE_KEY_ED25519="" \
	$(NODE_BIN) dist/index.js

# Go worker — handles the v8 JavaScript path for bucket BA. Reads work from the
# same Redis stream as the task-managers; orchestrator routes by bucket.
.PHONY: ephemeral-go-worker
ephemeral-go-worker: ephemeral-build-go-worker
	@echo "==> Starting go-worker (bucket BA)..."
	@SUPERBLOCKS_WORKER_GO_STORE_REDIS_HOST=127.0.0.1 \
	SUPERBLOCKS_WORKER_GO_STORE_REDIS_PORT=6379 \
	SUPERBLOCKS_WORKER_GO_STORE_REDIS_PASSWORD=$(EPHEMERAL_REDIS_PASSWORD) \
	SUPERBLOCKS_WORKER_GO_TRANSPORT_REDIS_HOST=127.0.0.1 \
	SUPERBLOCKS_WORKER_GO_TRANSPORT_REDIS_PORT=6379 \
	SUPERBLOCKS_WORKER_GO_TRANSPORT_REDIS_PASSWORD=$(EPHEMERAL_REDIS_PASSWORD) \
	SUPERBLOCKS_WORKER_GO_SUPERBLOCKS_KEY=$${SUPERBLOCKS_AGENT_KEY-dev-agent-key} \
	SUPERBLOCKS_WORKER_GO_WORKER_BUCKET=BA \
	SUPERBLOCKS_WORKER_GO_LOG_LEVEL=debug \
	SUPERBLOCKS_WORKER_GO_OTEL_COLLECTOR_HTTP_URL=http://127.0.0.1:4318 \
	$(GO_WORKER_BIN)

# ============================================================================
# Kill Targets
# ============================================================================

.PHONY: ephemeral-kill-orchestrator
ephemeral-kill-orchestrator:
	@echo "==> Killing orchestrator (port $(ORCH_HTTP_PORT))..."
	@-kill $$(lsof -ti:$(ORCH_HTTP_PORT)) 2>/dev/null; true
	@sleep 1

.PHONY: ephemeral-kill-task-manager-js
ephemeral-kill-task-manager-js:
	@echo "==> Killing JS task-manager (port $(JS_TM_VAR_STORE_GRPC_PORT))..."
	@-kill $$(lsof -ti:$(JS_TM_VAR_STORE_GRPC_PORT)) 2>/dev/null; true
	@sleep 1

.PHONY: ephemeral-kill-task-manager-js-aux
ephemeral-kill-task-manager-js-aux:
	@echo "==> Killing aux JS task-manager (port $(AUX_TM_VAR_STORE_GRPC_PORT))..."
	@-kill $$(lsof -ti:$(AUX_TM_VAR_STORE_GRPC_PORT)) 2>/dev/null; true
	@sleep 1

.PHONY: ephemeral-kill-task-manager-sdkapi
ephemeral-kill-task-manager-sdkapi:
	@echo "==> Killing SDK API task-manager (port $(SDKAPI_TM_VAR_STORE_GRPC_PORT))..."
	@-kill $$(lsof -ti:$(SDKAPI_TM_VAR_STORE_GRPC_PORT)) 2>/dev/null; true
	@sleep 1

.PHONY: ephemeral-kill-task-manager-py
ephemeral-kill-task-manager-py:
	@echo "==> Killing Python task-manager (port $(PY_TM_VAR_STORE_GRPC_PORT))..."
	@-kill $$(lsof -ti:$(PY_TM_VAR_STORE_GRPC_PORT)) 2>/dev/null; true
	@sleep 1

.PHONY: ephemeral-kill-js-sandbox
ephemeral-kill-js-sandbox:
	@echo "==> Killing JS sandbox (port $(JS_SANDBOX_PORT))..."
	@-kill $$(lsof -ti:$(JS_SANDBOX_PORT)) 2>/dev/null; true
	@sleep 1

.PHONY: ephemeral-kill-js-sandbox-sdkapi
ephemeral-kill-js-sandbox-sdkapi:
	@echo "==> Killing SDK API JS sandbox (port $(SDKAPI_SANDBOX_PORT))..."
	@-kill $$(lsof -ti:$(SDKAPI_SANDBOX_PORT)) 2>/dev/null; true
	@sleep 1

# go-worker does not bind a port; match by binary path.
.PHONY: ephemeral-kill-go-worker
ephemeral-kill-go-worker:
	@echo "==> Killing go-worker..."
	@-pkill -f "$(GO_WORKER_BIN)" 2>/dev/null; true
	@sleep 1

.PHONY: ephemeral-kill-all
ephemeral-kill-all: ephemeral-kill-orchestrator \
	ephemeral-kill-task-manager-js \
	ephemeral-kill-task-manager-js-aux \
	ephemeral-kill-task-manager-sdkapi \
	ephemeral-kill-task-manager-py \
	ephemeral-kill-js-sandbox \
	ephemeral-kill-js-sandbox-sdkapi \
	ephemeral-kill-go-worker
	@echo "==> All ephemeral services killed"

# ============================================================================
# Restart Targets
# ============================================================================

.PHONY: ephemeral-restart-orchestrator
ephemeral-restart-orchestrator: ephemeral-kill-orchestrator ephemeral-orchestrator

.PHONY: ephemeral-restart-task-manager-js
ephemeral-restart-task-manager-js: ephemeral-kill-task-manager-js ephemeral-task-manager-js

.PHONY: ephemeral-restart-task-manager-js-aux
ephemeral-restart-task-manager-js-aux: ephemeral-kill-task-manager-js-aux ephemeral-task-manager-js-aux

.PHONY: ephemeral-restart-task-manager-sdkapi
ephemeral-restart-task-manager-sdkapi: ephemeral-kill-task-manager-sdkapi ephemeral-task-manager-sdkapi

.PHONY: ephemeral-restart-task-manager-py
ephemeral-restart-task-manager-py: ephemeral-kill-task-manager-py ephemeral-task-manager-py

.PHONY: ephemeral-restart-js-sandbox
ephemeral-restart-js-sandbox: ephemeral-kill-js-sandbox ephemeral-js-sandbox

.PHONY: ephemeral-restart-js-sandbox-sdkapi
ephemeral-restart-js-sandbox-sdkapi: ephemeral-kill-js-sandbox-sdkapi ephemeral-js-sandbox-sdkapi

.PHONY: ephemeral-restart-go-worker
ephemeral-restart-go-worker: ephemeral-kill-go-worker ephemeral-go-worker

# ============================================================================
# All-in-One
# ============================================================================

EPHEMERAL_LOG_DIR ?= /tmp/ephemeral-dev

define bg_start
	@mkdir -p $(EPHEMERAL_LOG_DIR)
	@echo "==> Starting $(1) (log: $(EPHEMERAL_LOG_DIR)/$(1).log)..."
	@$(2) > $(EPHEMERAL_LOG_DIR)/$(1).log 2>&1 & echo $$! > $(EPHEMERAL_LOG_DIR)/$(1).pid
endef

# Services launched by ephemeral-up. Used for status/log iteration.
EPHEMERAL_SERVICES = orchestrator \
                     js-sandbox js-sandbox-sdkapi \
                     task-manager-js task-manager-js-aux task-manager-sdkapi task-manager-py \
                     go-worker

.PHONY: ephemeral-up
ephemeral-up: ephemeral-check-node ephemeral-kill-all ephemeral-deps ephemeral-build-go
	@echo ""
	@echo "==> Starting all services in background..."
	$(call bg_start,orchestrator,cd $(ORCH_SRC) && SUPERBLOCKS_AGENT_APP_ENV_TEST=ok \
		./orchestrator \
		--zen \
		--test=true \
		--log.level=debug \
		--transport.redis.password=$(EPHEMERAL_REDIS_PASSWORD) \
		--store.redis.password=$(EPHEMERAL_REDIS_PASSWORD) \
		--buckets.config=./buckets.minimal.json \
		--auth.jwt.enabled=true \
		--auth.jwt.jwks_url=$${SUPERBLOCKS_ORCHESTRATOR_AUTH_JWT_JWKS_URL:-https://staging-cdn.superblocks.com/.well-known/jwks.json} \
		--registration.enabled=$${SUPERBLOCKS_ORCHESTRATOR_REGISTRATION_ENABLED-true} \
		--quotas.enabled=false \
		--jobs.enabled=false \
		--http.bind=127.0.0.1 \
		--http.port=$(ORCH_HTTP_PORT) \
		--grpc.bind=127.0.0.1 \
		--metrics.port=$(ORCH_METRICS_PORT) \
		--pprof.enabled=true \
		--pprof.port=$(ORCH_PPROF_PORT) \
		--agent.host.url=$${SUPERBLOCKS_AGENT_HOST_URL:-http://localhost:$(ORCH_HTTP_PORT)} \
		--file.server.url=http://127.0.0.1:$(ORCH_HTTP_PORT)/v2/files \
		--superblocks.url=$${SUPERBLOCKS_ORCHESTRATOR_SUPERBLOCKS_URL:-$${SUPERBLOCKS_AGENT_SERVER_URL:-$${__SUPERBLOCKS_AGENT_SERVER_URL:-http://127.0.0.1:8080}}} \
		--superblocks.key=$${SUPERBLOCKS_AGENT_KEY-dev-agent-key} \
		--data.domain=$${SUPERBLOCKS_AGENT_DATA_DOMAIN-app.superblocks.com} \
		--worker.go.enabled=$${SUPERBLOCKS_ORCHESTRATOR_WORKER_GO_ENABLED-true} \
		--worker.stream.variant=$${SUPERBLOCKS_WORKER_STREAM_VARIANT-} \
		--otel.collector.http.url=http://127.0.0.1:4318)
	$(call bg_start,js-sandbox,cd $(JS_SANDBOX_DEPLOY_DIR) && env -u ELECTRON_RUN_AS_NODE \
		SUPERBLOCKS_WORKER_SANDBOX_TRANSPORT_GRPC_PORT=$(JS_SANDBOX_PORT) \
		SUPERBLOCKS_WORKER_SANDBOX_TRANSPORT_VARIABLE_STORE_ADDRESS=127.0.0.1:$(JS_TM_VAR_STORE_GRPC_PORT) \
		SUPERBLOCKS_WORKER_SANDBOX_TRANSPORT_VARIABLE_STORE_HTTP_ADDRESS=127.0.0.1:$(JS_TM_VAR_STORE_HTTP_PORT) \
		SUPERBLOCKS_WORKER_SANDBOX_TRANSPORT_STREAMING_PROXY_ADDRESS=127.0.0.1:$(JS_TM_STREAMING_PORT) \
		SUPERBLOCKS_WORKER_SANDBOX_TRANSPORT_INTEGRATION_EXECUTOR_ADDRESS=127.0.0.1:$(JS_TM_INTEGRATION_EXEC_PORT) \
		SUPERBLOCKS_AGENT_KEY="" \
		SUPERBLOCKS_TUNNEL_PRIVATE_KEY_RSA="" \
		SUPERBLOCKS_TUNNEL_PRIVATE_KEY_ED25519="" \
		$(NODE_BIN) dist/index.js)
	$(call bg_start,js-sandbox-sdkapi,cd $(JS_SANDBOX_DEPLOY_DIR) && env -u ELECTRON_RUN_AS_NODE \
		SUPERBLOCKS_WORKER_SANDBOX_TRANSPORT_GRPC_PORT=$(SDKAPI_SANDBOX_PORT) \
		SUPERBLOCKS_WORKER_SANDBOX_TRANSPORT_VARIABLE_STORE_ADDRESS=127.0.0.1:$(SDKAPI_TM_VAR_STORE_GRPC_PORT) \
		SUPERBLOCKS_WORKER_SANDBOX_TRANSPORT_VARIABLE_STORE_HTTP_ADDRESS=127.0.0.1:$(SDKAPI_TM_VAR_STORE_HTTP_PORT) \
		SUPERBLOCKS_WORKER_SANDBOX_TRANSPORT_STREAMING_PROXY_ADDRESS=127.0.0.1:$(SDKAPI_TM_STREAMING_PORT) \
		SUPERBLOCKS_WORKER_SANDBOX_TRANSPORT_INTEGRATION_EXECUTOR_ADDRESS=127.0.0.1:$(SDKAPI_TM_INTEGRATION_EXEC_PORT) \
		SUPERBLOCKS_AGENT_KEY="" \
		SUPERBLOCKS_TUNNEL_PRIVATE_KEY_RSA="" \
		SUPERBLOCKS_TUNNEL_PRIVATE_KEY_ED25519="" \
		$(NODE_BIN) dist/index.js)
	@echo "==> Waiting for sandboxes to bind (3s)..."
	@sleep 3
	$(call bg_start,task-manager-js,\
		$(TM_COMMON_ENV) \
		SUPERBLOCKS_WORKER_SANDBOX_WORKER_PLUGINS=$${SUPERBLOCKS_WORKER_SANDBOX_JS_PLUGINS-$(SUPERBLOCKS_WORKER_SANDBOX_JS_PLUGINS)} \
		SUPERBLOCKS_WORKER_SANDBOX_SANDBOX_ADDRESS=127.0.0.1:$(JS_SANDBOX_PORT) \
		SUPERBLOCKS_WORKER_SANDBOX_VARIABLE_STORE_GRPC_PORT=$(JS_TM_VAR_STORE_GRPC_PORT) \
		SUPERBLOCKS_WORKER_SANDBOX_VARIABLE_STORE_GRPC_ADDRESS=127.0.0.1:$(JS_TM_VAR_STORE_GRPC_PORT) \
		SUPERBLOCKS_WORKER_SANDBOX_VARIABLE_STORE_HTTP_PORT=$(JS_TM_VAR_STORE_HTTP_PORT) \
		SUPERBLOCKS_WORKER_SANDBOX_STREAMING_PROXY_GRPC_PORT=$(JS_TM_STREAMING_PORT) \
		SUPERBLOCKS_WORKER_SANDBOX_INTEGRATION_EXECUTOR_ENABLED=true \
		SUPERBLOCKS_WORKER_SANDBOX_INTEGRATION_EXECUTOR_GRPC_PORT=$(JS_TM_INTEGRATION_EXEC_PORT) \
		$(TM_BINARY))
	$(call bg_start,task-manager-js-aux,\
		$(TM_COMMON_ENV) \
		SUPERBLOCKS_WORKER_SANDBOX_WORKER_PLUGINS="$${SUPERBLOCKS_WORKER_SANDBOX_AUX_PLUGINS-$(SUPERBLOCKS_WORKER_SANDBOX_AUX_PLUGINS)}" \
		SUPERBLOCKS_WORKER_SANDBOX_SANDBOX_ADDRESS=127.0.0.1:$(JS_SANDBOX_PORT) \
		SUPERBLOCKS_WORKER_SANDBOX_VARIABLE_STORE_GRPC_PORT=$(AUX_TM_VAR_STORE_GRPC_PORT) \
		SUPERBLOCKS_WORKER_SANDBOX_VARIABLE_STORE_GRPC_ADDRESS=127.0.0.1:$(AUX_TM_VAR_STORE_GRPC_PORT) \
		SUPERBLOCKS_WORKER_SANDBOX_VARIABLE_STORE_HTTP_PORT=$(AUX_TM_VAR_STORE_HTTP_PORT) \
		SUPERBLOCKS_WORKER_SANDBOX_STREAMING_PROXY_GRPC_PORT=$(AUX_TM_STREAMING_PORT) \
		SUPERBLOCKS_WORKER_SANDBOX_INTEGRATION_EXECUTOR_ENABLED=false \
		SUPERBLOCKS_WORKER_SANDBOX_INTEGRATION_EXECUTOR_GRPC_PORT=$(AUX_TM_INTEGRATION_EXEC_PORT) \
		$(TM_BINARY))
	$(call bg_start,task-manager-sdkapi,\
		$(TM_COMMON_ENV) \
		SUPERBLOCKS_WORKER_SANDBOX_WORKER_PLUGINS=$${SUPERBLOCKS_WORKER_SANDBOX_SDKAPI_PLUGINS-$(SUPERBLOCKS_WORKER_SANDBOX_SDKAPI_PLUGINS)} \
		SUPERBLOCKS_WORKER_SANDBOX_SANDBOX_ADDRESS=127.0.0.1:$(SDKAPI_SANDBOX_PORT) \
		SUPERBLOCKS_WORKER_SANDBOX_VARIABLE_STORE_GRPC_PORT=$(SDKAPI_TM_VAR_STORE_GRPC_PORT) \
		SUPERBLOCKS_WORKER_SANDBOX_VARIABLE_STORE_GRPC_ADDRESS=127.0.0.1:$(SDKAPI_TM_VAR_STORE_GRPC_PORT) \
		SUPERBLOCKS_WORKER_SANDBOX_VARIABLE_STORE_HTTP_PORT=$(SDKAPI_TM_VAR_STORE_HTTP_PORT) \
		SUPERBLOCKS_WORKER_SANDBOX_STREAMING_PROXY_GRPC_PORT=$(SDKAPI_TM_STREAMING_PORT) \
		SUPERBLOCKS_WORKER_SANDBOX_INTEGRATION_EXECUTOR_ENABLED=true \
		SUPERBLOCKS_WORKER_SANDBOX_INTEGRATION_EXECUTOR_GRPC_PORT=$(SDKAPI_TM_INTEGRATION_EXEC_PORT) \
		$(TM_BINARY))
	$(call bg_start,task-manager-py,\
		$(TM_COMMON_ENV) \
		SUPERBLOCKS_WORKER_SANDBOX_WORKER_PLUGINS=$${SUPERBLOCKS_WORKER_SANDBOX_PY_PLUGINS-$(SUPERBLOCKS_WORKER_SANDBOX_PY_PLUGINS)} \
		SUPERBLOCKS_WORKER_SANDBOX_SANDBOX_ADDRESS=127.0.0.1:$(PY_SANDBOX_PORT) \
		SUPERBLOCKS_WORKER_SANDBOX_VARIABLE_STORE_GRPC_PORT=$(PY_TM_VAR_STORE_GRPC_PORT) \
		SUPERBLOCKS_WORKER_SANDBOX_VARIABLE_STORE_GRPC_ADDRESS=127.0.0.1:$(PY_TM_VAR_STORE_GRPC_PORT) \
		SUPERBLOCKS_WORKER_SANDBOX_VARIABLE_STORE_HTTP_PORT=$(PY_TM_VAR_STORE_HTTP_PORT) \
		SUPERBLOCKS_WORKER_SANDBOX_STREAMING_PROXY_GRPC_PORT=$(PY_TM_STREAMING_PORT) \
		SUPERBLOCKS_WORKER_SANDBOX_INTEGRATION_EXECUTOR_GRPC_PORT=$(PY_TM_INTEGRATION_EXEC_PORT) \
		$(TM_BINARY))
	$(call bg_start,go-worker,\
		SUPERBLOCKS_WORKER_GO_STORE_REDIS_HOST=127.0.0.1 \
		SUPERBLOCKS_WORKER_GO_STORE_REDIS_PORT=6379 \
		SUPERBLOCKS_WORKER_GO_STORE_REDIS_PASSWORD=$(EPHEMERAL_REDIS_PASSWORD) \
		SUPERBLOCKS_WORKER_GO_TRANSPORT_REDIS_HOST=127.0.0.1 \
		SUPERBLOCKS_WORKER_GO_TRANSPORT_REDIS_PORT=6379 \
		SUPERBLOCKS_WORKER_GO_TRANSPORT_REDIS_PASSWORD=$(EPHEMERAL_REDIS_PASSWORD) \
		SUPERBLOCKS_WORKER_GO_SUPERBLOCKS_KEY=$${SUPERBLOCKS_AGENT_KEY-dev-agent-key} \
		SUPERBLOCKS_WORKER_GO_WORKER_BUCKET=BA \
		SUPERBLOCKS_WORKER_GO_LOG_LEVEL=debug \
		SUPERBLOCKS_WORKER_GO_OTEL_COLLECTOR_HTTP_URL=http://127.0.0.1:4318 \
		$(GO_WORKER_BIN))
	@echo ""
	@echo "==> Waiting for services to start..."
	@sleep 5
	@failed=0; \
	for svc in $(EPHEMERAL_SERVICES); do \
		if [ -f $(EPHEMERAL_LOG_DIR)/$$svc.pid ] && kill -0 $$(cat $(EPHEMERAL_LOG_DIR)/$$svc.pid) 2>/dev/null; then \
			:; \
		else \
			echo "  ✗ $$svc failed to start (see $(EPHEMERAL_LOG_DIR)/$$svc.log)"; \
			failed=$$((failed + 1)); \
		fi; \
	done; \
	if [ $$failed -gt 0 ]; then \
		echo ""; \
		echo "==> $$failed service(s) failed. Check logs above."; \
		exit 1; \
	fi
	@echo "==> All services running in background"
	@echo "    Logs:   $(EPHEMERAL_LOG_DIR)/*.log"
	@echo "    make ephemeral-status   Check service status"

.PHONY: ephemeral-logs
ephemeral-logs:
	@set -- $(addprefix $(EPHEMERAL_LOG_DIR)/,$(addsuffix .log,$(EPHEMERAL_SERVICES))); \
	present=""; \
	for f in "$$@"; do [ -f "$$f" ] && present="$$present $$f"; done; \
	if [ -z "$$present" ]; then echo "No logs yet. Run make ephemeral-up first."; else tail -f $$present; fi

.PHONY: ephemeral-status
ephemeral-status:
	@echo "Ephemeral services:"
	@for svc in $(EPHEMERAL_SERVICES); do \
		if [ -f $(EPHEMERAL_LOG_DIR)/$$svc.pid ] && kill -0 $$(cat $(EPHEMERAL_LOG_DIR)/$$svc.pid) 2>/dev/null; then \
			echo "  ✓ $$svc (pid $$(cat $(EPHEMERAL_LOG_DIR)/$$svc.pid))"; \
		else echo "  ✗ $$svc (not running)"; fi; \
	done
	@echo ""
	@echo "Docker deps:"
	@docker compose -f $(EPHEMERAL_COMPOSE_FILE) ps --format "  {{.Name}}: {{.Status}}" 2>/dev/null || echo "  (not running)"

.PHONY: ephemeral-down
ephemeral-down: ephemeral-kill-all ephemeral-deps-down
	@rm -f $(EPHEMERAL_LOG_DIR)/*.pid
	@echo "==> Ephemeral stack stopped"

# ---------------------------------------------------------------------------
# Benchmarks
# ---------------------------------------------------------------------------

BENCH_ITERATIONS ?= 5

.PHONY: ephemeral-bench-sandbox-startup
ephemeral-bench-sandbox-startup: ephemeral-build-js-sandbox
	@bash $(JS_SANDBOX_DIR)/bench-sandbox-startup.sh $(BENCH_ITERATIONS)

# ---------------------------------------------------------------------------

.PHONY: ephemeral-help
ephemeral-help:
	@echo "Ephemeral Worker Development (from orchestrator repo)"
	@echo "  make ephemeral-up                     Kill, rebuild, start all (background)"
	@echo "  make ephemeral-down                   Stop everything"
	@echo "  make ephemeral-status                 Check what is running"
	@echo "  make ephemeral-logs                   Tail all logs"
	@echo "  make ephemeral-build                  Build all binaries (orch, task-manager, go-worker, js-sandbox)"
	@echo "  make ephemeral-build-js-sandbox       Force rebuild JS sandbox (after merge/pnpm install)"
	@echo "  make ephemeral-build-js-sandbox-if-needed  Rebuild JS sandbox only when .deploy, lockfile, or sources require it"
	@echo "  make ephemeral-bench-sandbox-startup  Benchmark sandbox startup latency"
	@echo ""
	@echo "Per-service targets (run in a dedicated terminal):"
	@echo "  make ephemeral-orchestrator"
	@echo "  make ephemeral-task-manager-js         plugins=javascript"
	@echo "  make ephemeral-task-manager-js-aux     plugins=*,-javascript,-javascriptsdkapi,-python"
	@echo "  make ephemeral-task-manager-sdkapi     plugins=javascriptsdkapi"
