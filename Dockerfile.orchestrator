# syntax=docker/dockerfile:1.9.0

# Allow the Go version to be configured
ARG DEBIAN_TRIXIE_VERSION=20250811
ARG GO_VERSION
ARG SB_GIT_COMMIT_SHA

# OpenTofu binary — invoked by the database-lifecycle worker (started with
# --database.lifecycle.worker.enabled=true) to apply native-DB Terraform
# modules. Helm wires SUPERBLOCKS_DATABASE_LIFECYCLE_TERRAFORM_BIN=tofu
# (helm/orchestrator/values.yaml `terraformBin`), so this binary must be
# on PATH in the runtime image. Version pinned to match the workspace nix
# devshell used by `just up local-orch` (workspace flake.nix → opentofu).
#
# Installed from OpenTofu's official packagecloud apt repository through
# scripts/install-opentofu.sh, using `apt-get install tofu=${TOFU_VERSION}`
# for version pinning. Both signing keys are verified against fingerprints
# pinned in that script before they are trusted by apt; bumping the keys
# requires a deliberate source edit.
# (The upstream ghcr.io/opentofu/opentofu image is unusable as a multi-stage
# source as of OpenTofu 1.10 — opentofu/opentofu#1931.)
FROM ghcr.io/superblocksteam/debian:trixie-${DEBIAN_TRIXIE_VERSION}-slim AS opentofu
ARG TOFU_VERSION=1.11.11
COPY --chmod=755 scripts/install-opentofu.sh /tmp/install-opentofu.sh
RUN /tmp/install-opentofu.sh

# amazon-ecr-credential-helper — OpenTofu uses Docker-style OCI credentials for
# oci://*.dkr.ecr.*.amazonaws.com module sources. Without this helper (and a
# matching DOCKER_CONFIG credsStore), tofu init fails with
# "basic credential not found" even when the pod has IRSA AWS credentials.
FROM ghcr.io/superblocksteam/debian:trixie-${DEBIAN_TRIXIE_VERSION}-slim AS ecr-login
ARG TARGETARCH
ARG ECR_LOGIN_VERSION=0.12.0
RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates curl \
    && rm -rf /var/lib/apt/lists/*
COPY --chmod=755 scripts/install-ecr-credential-helper.sh /tmp/install-ecr-credential-helper.sh
RUN TARGETARCH=${TARGETARCH} ECR_LOGIN_VERSION=${ECR_LOGIN_VERSION} /tmp/install-ecr-credential-helper.sh

# Builder base image
FROM ghcr.io/superblocksteam/golang:${GO_VERSION}-trixie AS builder

LABEL org.opencontainers.image.description "The Superblocks Orchestrator"

# https://github.com/rogchap/v8go/issues/381#issuecomment-1660576038
ENV DEBIAN_FRONTEND=noninteractive

# Set a directory to work from
WORKDIR /go/src/github.com/superblocksteam/orchestrator

# Install dependencies
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt/lists,sharing=locked \
    apt-get update && \
    apt-get upgrade -y && \
    apt-get install -y build-essential gcc

COPY go.mod go.sum ./
RUN --mount=type=cache,target=/go/pkg/mod go mod download

COPY . .

# Build our binary.
ARG SERVICE_VERSION
ARG EXTRA_GO_OPTIONS
RUN --mount=type=cache,target=/go/pkg/mod \
    --mount=type=cache,target=/root/.cache/go-build \
    make build-go SERVICE_VERSION=${SERVICE_VERSION} EXTRA_GO_OPTIONS=${EXTRA_GO_OPTIONS}

# Build the final image
FROM ghcr.io/superblocksteam/ubuntu:24.04 AS base

# Install CA certificates and apply security updates
RUN apt-get update \
    && apt-get upgrade -y \
    && apt-get install --no-install-recommends -y ca-certificates postgresql-client \
    && update-ca-certificates \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

FROM base

ARG SB_GIT_COMMIT_SHA

COPY --chmod=0644 workers/javascript/packages/plugins/postgres/src/rds-ca/global-bundle.pem /etc/ssl/certs/aws-rds-global-bundle.pem

# Create and switch to a non-root user
RUN useradd -m -u 1001 orchestrator
USER orchestrator

# Copy in our compiled binary
COPY --from=builder /go/src/github.com/superblocksteam/orchestrator/orchestrator         /orchestrator
COPY --from=builder /go/src/github.com/superblocksteam/orchestrator/buckets.json         /buckets.json
COPY --from=builder /go/src/github.com/superblocksteam/orchestrator/buckets.minimal.json /buckets.minimal.json
COPY --from=builder /go/src/github.com/superblocksteam/orchestrator/buckets.minimal.json /buckets.minimal.json
COPY --from=builder /go/src/github.com/superblocksteam/orchestrator/flags.json           /flags.json

# OpenTofu — required by the database-lifecycle worker. Inert for other
# orchestrator roles. See top of file for context.
COPY --from=opentofu /usr/bin/tofu /usr/local/bin/tofu
COPY --from=ecr-login /usr/local/bin/docker-credential-ecr-login /usr/local/bin/docker-credential-ecr-login
COPY --chmod=644 scripts/oci-docker-config.json /etc/superblocks/docker/config.json

# Immutable Native Database modules used by local `./modules/...` lifecycle
# sources. Populate with scripts/ci-prepare-native-db-modules.sh before build.
COPY --chown=1001:1001 build/native-db-modules /opt/superblocks/terraform-modules

ENV DOCKER_CONFIG=/etc/superblocks/docker
ENV SB_GIT_REPOSITORY_URL "https://github.com/superblocksteam/orchestrator"
ENV SB_GIT_COMMIT_SHA     ${SB_GIT_COMMIT_SHA}

# Start the service
ENTRYPOINT ["/orchestrator"]
