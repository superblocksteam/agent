# syntax=docker/dockerfile:1.9.0

# Build stage (using Debian for glibc compatibility with v8go)
ARG GO_VERSION=1.26.3
FROM ghcr.io/superblocksteam/golang:${GO_VERSION}-trixie AS builder

WORKDIR /app

# Copy root go.mod first (for replace directive)
COPY go.mod go.sum ./

# Copy the internal packages (superblocks agent)
COPY pkg/ ./pkg/
COPY types/ ./types/
COPY internal/ ./internal/

# Copy workers/shared (used by task-manager)
COPY workers/shared/ ./workers/shared/

# Copy task-manager go.mod and download dependencies
COPY workers/ephemeral/task-manager/go.mod workers/ephemeral/task-manager/go.sum* ./workers/ephemeral/task-manager/

WORKDIR /app/workers/ephemeral/task-manager
RUN --mount=type=cache,target=/go/pkg/mod go mod download

# Copy source code and pre-generated protobuf files
COPY workers/ephemeral/task-manager/internal/ ./internal/
COPY workers/ephemeral/task-manager/cmd/ ./cmd/

# Build the binary (CGO needed for v8go dependency in pkg/errors)
RUN --mount=type=cache,target=/go/pkg/mod \
    --mount=type=cache,target=/root/.cache/go-build \
    CGO_ENABLED=1 GOOS=linux go build -o task-manager ./cmd/task-manager

# Runtime stage (distroless includes glibc + ca-certificates, no shell/package manager)
FROM ghcr.io/superblocksteam/gcr.io/distroless/cc-debian13:nonroot@sha256:e1fd250ce83d94603e9887ec991156a6c26905a6b0001039b7a43699018c0733

WORKDIR /app

# Copy the binary
COPY --from=builder /app/workers/ephemeral/task-manager/task-manager .

# Kubernetes probes use `cat /tmp/worker_healthy`; distroless has no coreutils
COPY --from=builder /bin/cat /bin/cat

# Default environment variables for Task Manager
# Note: sandbox.address is NOT set - defaults to job mode (dynamic Kubernetes Jobs)
# For static mode (Docker Compose), set SUPERBLOCKS_WORKER_SANDBOX_SANDBOX_ADDRESS
ENV SUPERBLOCKS_WORKER_SANDBOX_TRANSPORT_REDIS_HOST=redis \
    SUPERBLOCKS_WORKER_SANDBOX_TRANSPORT_REDIS_PORT=6379 \
    SUPERBLOCKS_WORKER_SANDBOX_WORKER_LANGUAGE=javascript \
    SUPERBLOCKS_WORKER_SANDBOX_WORKER_CONSUMER_GROUP=sandbox-javascript-workers \
    SUPERBLOCKS_WORKER_SANDBOX_GRPC_PORT=50050 \
    SUPERBLOCKS_WORKER_SANDBOX_OTEL_COLLECTOR_HTTP_URL=http://otel-desktop-viewer:4318

EXPOSE 50050 8080

CMD ["./task-manager"]
