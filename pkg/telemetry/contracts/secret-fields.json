{
  "_source": "packages/telemetry/src/common/log-sanitizer.ts",
  "_sync": "Run scripts/sync-ts-telemetry-contracts.sh to regenerate from TS source.",
  "exact": [
    "access_token",
    "accesstoken",
    "api_key",
    "apikey",
    "auth_token",
    "authorization",
    "bearer",
    "cookie",
    "credentials",
    "jwt",
    "passwd",
    "password",
    "private_key",
    "privatekey",
    "refresh_token",
    "refreshtoken",
    "secret",
    "token",
    "x-api-key"
  ],
  "patterns": [
    "(?i)(?:^|[._-])password(?:[._-]|$)",
    "(?i)(?:^|[._-])passwd(?:[._-]|$)",
    "(?i)(?:^|[._-])secret(?:[._-]|$)",
    "(?i)(?:^|[._-])private[._-]?key(?:[._-]|$)",
    "(?i)(?:^|[._-])token(?:[._-]|$)",
    "(?i)(?:^|[._-])jwt(?:[._-]|$)",
    "(?i)(?:^|[._-])bearer(?:[._-]|$)",
    "(?i)(?:^|[._-])credentials?(?:[._-]|$)",
    "(?i)api[._-]?key",
    "(?i)x[._-]api[._-]key",
    "(?i)auth[._-]token"
  ]
}
