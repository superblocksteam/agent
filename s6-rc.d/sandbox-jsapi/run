#!/command/with-contenv sh

# gRPC server port (where task-manager-jsapi connects to this sandbox)
export SUPERBLOCKS_WORKER_SANDBOX_TRANSPORT_GRPC_PORT="${SUPERBLOCKS_WORKER_SANDBOX_TRANSPORT_GRPC_PORT_JSAPI:-50071}"

# Variable store and streaming proxy addresses (task-manager-jsapi endpoints)
export SUPERBLOCKS_WORKER_SANDBOX_TRANSPORT_VARIABLE_STORE_ADDRESS="${SUPERBLOCKS_WORKER_SANDBOX_TRANSPORT_VARIABLE_STORE_ADDRESS_JSAPI:-localhost:50070}"
export SUPERBLOCKS_WORKER_SANDBOX_TRANSPORT_VARIABLE_STORE_HTTP_ADDRESS="${SUPERBLOCKS_WORKER_SANDBOX_TRANSPORT_VARIABLE_STORE_HTTP_ADDRESS_JSAPI:-localhost:8087}"
export SUPERBLOCKS_WORKER_SANDBOX_TRANSPORT_STREAMING_PROXY_ADDRESS="${SUPERBLOCKS_WORKER_SANDBOX_TRANSPORT_STREAMING_PROXY_ADDRESS_JSAPI:-localhost:50072}"

# Integration executor address (task-manager-jsapi runs the integration executor gRPC service)
export SUPERBLOCKS_WORKER_SANDBOX_TRANSPORT_INTEGRATION_EXECUTOR_ADDRESS="${SUPERBLOCKS_WORKER_SANDBOX_TRANSPORT_INTEGRATION_EXECUTOR_ADDRESS_JSAPI:-localhost:50073}"

# Logging
export SUPERBLOCKS_WORKER_SANDBOX_LOG_LEVEL="${SUPERBLOCKS_WORKER_SANDBOX_LOG_LEVEL:-${SUPERBLOCKS_AGENT_LOG_LEVEL:-info}}"

# Required env vars (not used at runtime but expected at import time by worker.js)
export SUPERBLOCKS_AGENT_KEY="${SUPERBLOCKS_AGENT_KEY:-}"
export SUPERBLOCKS_TUNNEL_PRIVATE_KEY_RSA="${SUPERBLOCKS_TUNNEL_PRIVATE_KEY_RSA:-}"
export SUPERBLOCKS_TUNNEL_PRIVATE_KEY_ED25519="${SUPERBLOCKS_TUNNEL_PRIVATE_KEY_ED25519:-}"

# Environment variables to inherit into the sandbox
export SUPERBLOCKS_WORKER_EXECUTION_ENV_INCLUSION_LIST="${SB_EXECUTION_ENV_INCLUSION_LIST:-${SUPERBLOCKS_EXECUTION_ENV_INCLUSION_LIST}}"

echo "{\"level\":\"info\",\"ts\":$(date +%s%3N),\"msg\":\"starting component sandbox-jsapi\",\"component\":\"s6\"}"
node /app/sandbox-js/dist/index.js
