{
  "name": "@superblocks/fleet.javascriptsdkapi",
  "version": "0.0.1",
  "description": "Fleet that handles only the javascriptsdkapi plugin (for separate process local dev).",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "scripts": {
    "start": "nodemon",
    "clean": "rm -rf ./dist *tsbuildinfo",
    "build": "swc ./src --out-dir ./dist --config-file .swcrc",
    "lint": "eslint . --ext ts",
    "lint:fix": "eslint . --ext ts --fix",
    "typecheck": "npx tsc"
  },
  "dependencies": {
    "@superblocks/worker.js": "workspace:*",
    "@superblocksteam/javascript-sdk-api": "workspace:*",
    "ion-js": "5.2.1",
    "jsbi": "4.3.0"
  },
  "devDependencies": {
    "@swc/cli": "catalog:",
    "@swc/core": "catalog:",
    "@types/node": "catalog:",
    "@typescript-eslint/eslint-plugin": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-import-resolver-typescript": "catalog:",
    "eslint-plugin-import": "catalog:",
    "nodemon": "catalog:",
    "ts-node": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": "20.19.5"
  }
}
