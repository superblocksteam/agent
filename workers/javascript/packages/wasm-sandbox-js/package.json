{
  "name": "@superblocks/wasm-sandbox-js",
  "private": true,
  "version": "0.0.1",
  "description": "WASM-based sandbox for secure JavaScript evaluation using QuickJS",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "engines": {
    "node": "20.19.5"
  },
  "scripts": {
    "build": "pnpm run clean && tsc",
    "clean": "rimraf ./dist *tsbuildinfo",
    "lint": "eslint . --ext ts --max-warnings 0 --cache --cache-strategy content --cache-location ~/.cache/eslint/",
    "lint:fix": "eslint . --ext ts --fix --cache --cache-strategy content --cache-location ~/.cache/eslint/",
    "typecheck": "tsc --noEmit",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --coverage --runInBand"
  },
  "dependencies": {
    "quickjs-emscripten-core": "workspace:*",
    "@jitl/quickjs-wasmfile-release-sync": "workspace:*",
    "lodash": "^4.17.21",
    "moment": "2.29.4"
  },
  "devDependencies": {
    "@jitl/quickjs-wasmfile-debug-sync": "workspace:*",
    "@jest/globals": "^29.7.0",
    "@types/jest": "catalog:",
    "@types/lodash": "catalog:",
    "@types/node": "catalog:",
    "@typescript-eslint/eslint-plugin": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-import-resolver-typescript": "catalog:",
    "eslint-plugin-import": "catalog:",
    "eslint-plugin-prettier": "catalog:",
    "jest": "catalog:",
    "prettier": "catalog:",
    "rimraf": "catalog:",
    "ts-jest": "^29.1.0",
    "typescript": "catalog:"
  }
}
