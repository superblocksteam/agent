{
  "name": "@superblocksteam/javascript",
  "version": "0.0.1",
  "description": "Superblocks JavaScript Plugin",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": "./dist/src/index.js",
    "./bootstrap": "./src/bootstrap.js"
  },
  "engines": {
    "node": "20.19.5"
  },
  "scripts": {
    "start": "chokidar '**/*.ts' '../../shared-backend/**/*' -c 'npm run build'",
    "build": "swc src -d dist",
    "clean": "rimraf ./dist *tsbuildinfo",
    "lint": "eslint . --ext ts --max-warnings 0 --cache --cache-strategy content --cache-location ~/.cache/eslint/",
    "lint:fix": "eslint . --ext ts --fix --cache --cache-strategy content --cache-location ~/.cache/eslint/",
    "lint:precommit": "eslint --ext ts --fix --cache --cache-strategy content --cache-location ~/.cache/eslint/",
    "typecheck": "tsc",
    "check": "pnpm run typecheck && npm run lint",
    "test": "jest --coverage --detectOpenHandles",
    "pre-commit": "tsc && lint-staged"
  },
  "dependencies": {
    "@superblocks/shared": "workspace:*",
    "axios": "1.8.3",
    "base64url": "3.0.1",
    "deasync": "0.1.30",
    "esprima": "4.0.1",
    "lodash": "4.17.21",
    "moment": "2.30.1",
    "vm2": "^3.10.5",
    "xmlbuilder2": "3.1.1"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@swc/cli": "catalog:",
    "@swc/core": "catalog:",
    "@swc/jest": "catalog:",
    "@types/esprima": "^4.0.3",
    "@types/jest": "catalog:",
    "@types/lodash": "catalog:",
    "@types/node": "catalog:",
    "@typescript-eslint/eslint-plugin": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "chokidar-cli": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-import-resolver-typescript": "catalog:",
    "eslint-plugin-import": "catalog:",
    "eslint-plugin-prettier": "catalog:",
    "jest": "catalog:",
    "prettier": "catalog:",
    "rimraf": "catalog:",
    "ts-jest": "catalog:",
    "ts-node": "catalog:",
    "typescript": "catalog:"
  }
}
