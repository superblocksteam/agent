{
  "name": "@superblocksteam/javascript-sdk-api-wasm",
  "version": "0.0.1",
  "type": "commonjs",
  "description": "Superblocks SDK API Plugin (WASM runtime)",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "engines": {
    "node": "20.19.5"
  },
  "scripts": {
    "bundle:sdk-api": "node scripts/bundle-sdk-api.mjs",
    "build": "swc src -d dist && pnpm run bundle:sdk-api",
    "clean": "rimraf ./dist *tsbuildinfo src/bundles/sdk-api.iife.js",
    "lint": "eslint . --ext ts --max-warnings 0 --cache --cache-strategy content --cache-location ~/.cache/eslint/",
    "lint:fix": "eslint . --ext ts --fix --cache --cache-strategy content --cache-location ~/.cache/eslint/",
    "typecheck": "tsc --noEmit",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --coverage --runInBand"
  },
  "dependencies": {
    "@superblocks/shared": "workspace:*",
    "@superblocks/wasm-sandbox-js": "workspace:*"
  },
  "devDependencies": {
    "@superblocksteam/sdk-api": "0.0.6",
    "@swc/cli": "catalog:",
    "@swc/core": "catalog:",
    "@types/jest": "catalog:",
    "@types/node": "catalog:",
    "@typescript-eslint/eslint-plugin": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "esbuild": "^0.25.0",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-import-resolver-typescript": "catalog:",
    "eslint-plugin-import": "catalog:",
    "eslint-plugin-prettier": "catalog:",
    "jest": "catalog:",
    "prettier": "catalog:",
    "rimraf": "catalog:",
    "ts-jest": "catalog:",
    "typescript": "catalog:"
  }
}
