{
  "name": "@superblocksteam/adls",
  "version": "0.0.1",
  "description": "Superblocks Azure Data Lake Storage Plugin",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "engines": {
    "node": "20.19.5"
  },
  "scripts": {
    "start": "chokidar '**/*.ts' '../../shared-backend/**/*' -c 'pnpm run build'",
    "build": "swc src -d dist",
    "clean": "rimraf ./dist *tsbuildinfo",
    "lint": "eslint . --ext ts --max-warnings 0 --cache --cache-strategy content --cache-location ~/.cache/eslint/",
    "lint:fix": "eslint . --ext ts --fix --cache --cache-strategy content --cache-location ~/.cache/eslint/",
    "lint:precommit": "eslint --ext ts --fix --cache --cache-strategy content --cache-location ~/.cache/eslint/",
    "typecheck": "tsc",
    "check": "pnpm run typecheck && pnpm run lint",
    "test": "jest --coverage",
    "pre-commit": "tsc && lint-staged"
  },
  "dependencies": {
    "@azure/identity": "^3.4.2",
    "@azure/storage-file-datalake": "^12.15.0",
    "@bufbuild/protobuf": "1.3.0",
    "@superblocks/shared": "workspace:*",
    "@superblocksteam/types": "workspace:*"
  },
  "devDependencies": {
    "@swc/cli": "catalog:",
    "@swc/core": "catalog:",
    "@swc/jest": "catalog:",
    "@types/jest": "catalog:",
    "@types/lodash": "catalog:",
    "@types/node": "catalog:",
    "@typescript-eslint/eslint-plugin": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "chokidar-cli": "catalog:",
    "dotenv": "^16.3.1",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-import-resolver-typescript": "catalog:",
    "eslint-plugin-import": "catalog:",
    "eslint-plugin-prettier": "catalog:",
    "jest": "catalog:",
    "lodash": "^4.17.23",
    "prettier": "catalog:",
    "rimraf": "catalog:",
    "typescript": "catalog:"
  }
}
