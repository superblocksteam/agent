{
  "name": "@superblocks/shared",
  "version": "0.0.1",
  "private": true,
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "scripts": {
    "start": "chokidar '**/*.ts' '../shared/dist/**/*' -c 'pnpm run build'",
    "build": "pnpm run clean && tsc",
    "clean": "rimraf ./dist *tsbuildinfo",
    "lint": "eslint . --ext ts --max-warnings 0 --cache --cache-strategy content --cache-location ~/.cache/eslint/",
    "lint:fix": "eslint . --ext ts --fix --cache --cache-strategy content --cache-location ~/.cache/eslint/",
    "lint:precommit": "eslint --ext ts --fix --cache --cache-strategy content --cache-location ~/.cache/eslint/",
    "typecheck": "tsc",
    "check": "pnpm run typecheck && pnpm run lint",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "pre-commit": "tsc && lint-staged"
  },
  "dependencies": {
    "@aws-sdk/client-sts": "3.758.0",
    "@aws-sdk/credential-providers": "3.758.0",
    "@bufbuild/protobuf": "1.3.0",
    "@lezer/common": "0.16.1",
    "@lezer/lr": "0.16.3",
    "@mmkal/truncate-json": "^1.6.0",
    "@opentelemetry/api": "1.3.0",
    "@opentelemetry/semantic-conventions": "^1.6.0",
    "@rockset/client": "0.8.32",
    "@server-sent-stream/node": "^1.0.5",
    "@superblocks/wasm-sandbox-js": "workspace:*",
    "@superblocksteam/types": "workspace:*",
    "@types/esprima": "4.0.6",
    "@types/estree": "^1.0.5",
    "ajv": "8.18.0",
    "ajv-errors": "3.0.0",
    "ajv-formats": "2.1.1",
    "axios": "1.13.5",
    "base64url": "3.0.1",
    "bson": "4.6.5",
    "date-fns": "3.3.1",
    "deasync": "0.1.29",
    "express": "4.21.2",
    "form-data": "^4.0.4",
    "google-protobuf": "catalog:",
    "iconv-lite": "^0.6.3",
    "isomorphic-ws": "^5.0.0",
    "js-base64": "^3.7.5",
    "json5": "2.2.3",
    "lodash": "^4.17.23",
    "moment": "2.29.4",
    "mustache": "4.2.0",
    "normalizr": "3.6.2",
    "pino": "6.11.0",
    "piscina": "^3.2.0",
    "prom-client": "14.2.0",
    "semver": "^7.6.0",
    "slugify": "^1.6.6",
    "ssh2": "1.15.0",
    "tunnel-ssh": "5.1.1",
    "uuid": "8.3.2",
    "vm2": "3.10.5",
    "whatwg-mimetype": "^3.0.0",
    "xmlbuilder2": "3.0.2"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@swc/cli": "catalog:",
    "@swc/core": "catalog:",
    "@swc/jest": "catalog:",
    "@types/deasync": "0.1.5",
    "@types/jest": "catalog:",
    "@types/lodash": "catalog:",
    "@types/node": "catalog:",
    "@types/whatwg-mimetype": "^3.0.0",
    "@typescript-eslint/eslint-plugin": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "chokidar-cli": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-import-resolver-typescript": "catalog:",
    "eslint-plugin-import": "catalog:",
    "jest": "catalog:",
    "rimraf": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">= 22"
  }
}
